# ── Stock Platform – Umgebungsvariablen (Vorlage) ─────────────
# Diese Datei DARF commitet werden. Werte sind Platzhalter.
#
# Anleitung:
#   cp .env.example .env
#   Dann die echten Werte eintragen.
# Die echte .env wird via .gitignore NIEMALS commitet.

# ── Gluetun / ProtonVPN (WireGuard) ──────────────────────────
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard
FREE_ONLY=on
SERVER_COUNTRIES=Netherlands
FIREWALL_OUTBOUND_SUBNETS=172.16.0.0/12

# WireGuard-Zugangsdaten aus der von Proton VPN heruntergeladenen *.conf-Datei:
WIREGUARD_PRIVATE_KEY=dein-wireguard-private-key-hier-eintragen
WIREGUARD_ADDRESSES=10.x.x.x/32
